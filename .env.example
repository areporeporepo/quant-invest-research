# Copy this file to `.env` and fill in your own keys. NEVER commit `.env`.
# The service reads everything from the environment — no secrets in code.

# Which price provider to use: dnse | alphavantage | finnhub | stub
# "dnse" (default) serves REAL Vietnamese HOSE/HNX daily data with NO key.
# "stub" returns synthetic data for offline pipeline testing.
PRICE_PROVIDER=dnse

# Default asset. Vinhomes trades on HOSE as VHM (bare code for dnse).
DEFAULT_TICKER=VHM

# Annualized risk-free rate used in the Sharpe ratio (e.g. 0.04 = 4%).
RISK_FREE_RATE=0.04

# --- Market data providers (pick one, set PRICE_PROVIDER to match) ---
# Alpha Vantage free key: https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_API_KEY=
# Finnhub free key: https://finnhub.io/register
FINNHUB_API_KEY=

# --- Satellite / alt-data ---
# Planet.com (PlanetScope 3 m imagery). Get the key from your Planet account
# (or your password manager) and put it HERE — never in chat or commits.
PL_API_KEY=

